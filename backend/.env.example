# Required
MODEL_PATH=../data/model_artifacts_v2.pkl
GROQ_API_KEY=gsk_your_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_or_anon_key

# Optional — second Groq account; becomes the agent's primary key with failover
# GROQ_API_KEY_2=gsk_second_key_here

# Optional — LangSmith agent tracing (zero code changes)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_your_key_here
# LANGSMITH_PROJECT=flight-agent
